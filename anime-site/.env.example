# Optional. Public application token from https://yummyani.me/dev/applications
# The public endpoints work without it, but the API docs recommend supplying one.
VITE_YUMMY_APP_TOKEN=

# Optional. Private token (higher rate limits). Takes priority over public token.
VITE_YUMMY_PRIVATE_TOKEN=

# Optional override for backend API URL.
# Dev example: http://localhost:3001/api
# Prod behind domain reverse-proxy: /api
VITE_QIK_API_URL=
