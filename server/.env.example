# Port for the NestJS API (default 3001)
PORT=3001

# Secret used to sign JWT tokens. Change this in production.
JWT_SECRET=qik-anime-dev-secret-change-me

# Optional app root used for relative DB_PATH/UPLOAD_DIR values.
# Defaults to the server project root (stable in both dev and start:prod).
APP_ROOT=

# SQLite database file path (absolute or relative to APP_ROOT)
DB_PATH=data/qik-anime.db

# Uploaded files directory (absolute or relative to APP_ROOT)
UPLOAD_DIR=uploads

# Optional comma-separated CORS origins.
# In production, when empty, only quickik.ru domains are allowed.
CORS_ORIGINS=

# Secret code to claim admin rights via the /admin page.
# Visit /admin, enter this code, and your account becomes admin.
ADMIN_SECRET=change-me-to-something-secret
